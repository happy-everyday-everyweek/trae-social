# keystore.properties 模板（IMPL-42）
#
# 使用方法：
# 1. 复制本文件为 keystore.properties（cp keystore.properties.example keystore.properties）
# 2. 生成签名密钥：keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias release
# 3. 填写下方字段（storeFile 为 .jks 文件相对项目根目录的路径）
# 4. keystore.properties 与 *.jks 已在 .gitignore 中排除，不会提交到版本库
#
# 注意：keystore.properties 不存在时，release 构建会回退使用 debug 签名。

storeFile=release.jks
storePassword=your_store_password
keyAlias=release
keyPassword=your_key_password
