<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 开机自启权限（实际声明在 app 模块，此处避免重复声明） -->

    <application>

        <!-- #69/#88：开机自启接收器：仅注册 BOOT_COMPLETED。
             M4 修复：移除 LOCKED_BOOT_COMPLETED 与 directBootAware=true，
             因 WorkManager 不支持 Direct Boot 模式，设备未解锁时调用会崩溃。 -->
        <receiver
            android:name="com.trae.social.core.scheduler.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
