<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ 网络相关 ============ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ============ 相机与媒体访问 ============ -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- API 33+ 使用细粒度媒体权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- IMPL-46：READ_EXTERNAL_STORAGE 已移除，EditorModeContent 使用 PickVisualMedia 系统代理，无需存储权限 -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- ============ 前台服务（调度任务常驻） ============ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+ 必须声明具体的前台服务类型（IMPL-17：specialUse 替代 dataSync） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ============ 通知（API 33+ 运行时申请） ============ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ============ 开机自启 / 唤醒 ============ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- IMPL-46：REQUEST_IGNORE_BATTERY_OPTIMIZATIONS 已移除（Play 政策敏感且未在运行时申请） -->

    <application
        android:name=".SocialApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Social"
        tools:targetApi="34">

        <!-- 主入口 Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Social">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 调度前台服务：specialUse 类型（IMPL-17：dataSync 在 Android 14+ 有 6 小时配额限制） -->
        <service
            android:name="com.trae.social.core.scheduler.SchedulerForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="social_ai_scheduler_keepalive" />
        </service>

        <!-- IMPL-18：开机自启接收器，注册 BOOT_COMPLETED + LOCKED_BOOT_COMPLETED -->
        <receiver
            android:name="com.trae.social.core.scheduler.BootReceiver"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 移除 androidx.startup 默认的 WorkManager 初始化，
             改由 SocialApp 实现 Configuration.Provider 接入 HiltWorkerFactory -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- FileProvider：用于相机拍照后的文件分享 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
